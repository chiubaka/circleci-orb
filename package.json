{
  "name": "@chiubaka/circleci-orb",
  "version": "0.16.2",
  "private": true,
  "description": "CircleCI Orb for common Chiubaka Technologies CI/CD tasks",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "lint": "pnpm lint:scripts && pnpm lint:yml",
    "lint:yml": "yamllint ./src",
    "lint:scripts": "bash scripts/run-shellcheck.sh",
    "build": "circleci local execute --skip-checkout orb-tools/pack",
    "prepare": "husky install",
    "release:orb": "bash scripts/push-orb-release-tag.sh",
    "test": "bats -r ./test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiubaka/circleci-orb.git"
  },
  "keywords": [
    "circleci",
    "circleci-orb",
    "chiubaka"
  ],
  "author": "Daniel Chiu",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/chiubaka/circleci-orb/issues"
  },
  "homepage": "https://github.com/chiubaka/circleci-orb#readme",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "bats": "^1.7.0",
    "bats-assert": "^2.0.0",
    "bats-file": "bats-core/bats-file#c7df56c",
    "bats-mock": "grayhemp/bats-mock#48fce74",
    "bats-support": "^0.3.0",
    "husky": "^8.0.1",
    "shellcheck": "^1.1.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "shellcheck"
    ]
  }
}
